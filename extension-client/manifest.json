{
  "manifest_version": 2,
  "name": "HumanPass Client",
  "version": "1.0.0",
  "description": "Detecta hCaptcha, lo envía a HumanPass y auto-inyecta el token resuelto.",
  "permissions": ["activeTab", "storage", "tabs", "notifications", "https://*/*", "http://*/*"],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle",
    "all_frames": false
  }],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": { "48": "icons/icon48.png" },
    "default_title": "HumanPass Client"
  },
  "icons": { "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
